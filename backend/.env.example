APP_ENV=dev
DB_CONNECTION_STRING=postgresql+asyncpg://postgres:securepassword@localhost:5432/athomedatabase
REDIS_URL=redis://redis:6379/0

# Public host the app is served under - drives the auth redirect URLs, CORS
# origin, and cookie host. Locally this is myapp.localhost (docker nginx);
# behind the gateway set it to your real domain, e.g. myapp.example.com.
CURRENT_DOMAIN=myapp.localhost

# The trojonetworks identity provider network this app authenticates against.
NETWORK_ID=00000000-0000-0000-0000-000000000000

# Identity provider URLs. LOGIN_BASE_URL is where the *browser* is sent to
# log in (must be reachable from every device that uses the app);
# LOGIN_API_URL is the server-to-server address the backend calls.
LOGIN_BASE_URL=https://mytpn.tijmensimons.nl
LOGIN_API_URL=https://mytpn.tijmensimons.nl

POSTGRES_USER=postgres
POSTGRES_PASSWORD=securepassword
POSTGRES_DB=athomedatabase
